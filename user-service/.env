PORT=8081

POSTGRES_HOST=db-user
POSTGRES_PORT=5432
POSTGRES_DB=user_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Qq1234567
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=5m

REDIS_HOST=redis-user
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_STATUS_TTL=5m
REDIS_PROFILE_TTL=30m
REDIS_SETTINGS_TTL=1h

KAFKA_ENABLED=true
KAFKA_BROKERS=kafka:9092
KAFKA_CONSUMER_GROUP_ID=user-service-group
KAFKA_CONSUMER_GROUP_REGISTRATION=user-service-registration-group
KAFKA_REQUEST_TOPIC=user-service.requests
KAFKA_RESPONSE_TOPIC=user-service.responses
KAFKA_EVENT_TOPIC=user.events
KAFKA_AUTH_EVENT_TOPIC=auth.events
KAFKA_CONSUMER_MIN_BYTES=10240
KAFKA_CONSUMER_MAX_BYTES=10485760
KAFKA_CONSUMER_MAX_WAIT=1s
KAFKA_PRODUCER_REQUIRED_ACKS=1
KAFKA_PRODUCER_TIMEOUT=5s
KAFKA_REQUEST_TIMEOUT=5s
KAFKA_RESPONSE_TIMEOUT=10s